# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=loanlight
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# MinIO (S3-compatible)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=loan-documents

# Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6
# Set to claude-opus-4-7 for higher accuracy on re-extractions

# Ingestion
LOAN_DOCS_PATH=
EXTRACTION_CONCURRENCY=3

# App
PORT=3000
NODE_ENV=development
# Set a strong secret to protect write endpoints (POST /ingestion/*, POST /documents/:id/re-extract, /admin/queues)
# Pass as header: x-api-key: <value>. Leave unset to disable auth in local dev.
ADMIN_API_KEY=
